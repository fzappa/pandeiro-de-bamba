# Copie para .env (ou .env.local) e ajuste conforme necessário.
# Nenhuma destas variáveis é obrigatória — sem elas, o app roda aberto,
# sem login e sem analytics.

# Restringe o acesso por IP (lista separada por vírgula).
# ALLOWED_IPS=203.0.113.10,198.51.100.42

# No Render, necessário quando ALLOWED_IPS está definida.
# ADDRESS_HEADER=true-client-ip

# Restringe o acesso com usuário e senha (tela de login própria).
# BASIC_AUTH_USER=alan
# BASIC_AUTH_PASSWORD=troque-por-uma-senha-forte

# ID de mensuração do Google Analytics 4 (ex.: G-XXXXXXXXXX).
# Sem esta variável, nenhum script de analytics é carregado.
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
