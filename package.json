{
  "name": "pandeiro-de-bamba",
  "private": true,
  "version": "1.0.0",
  "license": "AGPL-3.0",
  "author": {
    "name": "Alan Franco",
    "email": "alanfr.engel@proton.me"
  },
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node build",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "docker:scan": "trivy image --exit-code 1 --severity HIGH,CRITICAL pandeiro-de-bamba:latest",
    "lint": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "format": "prettier --write .",
    "test": "node --experimental-strip-types --test tests/**/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "audit:deps": "pnpm audit --audit-level high --prod",
    "validate": "pnpm run lint && pnpm run check && pnpm run test && pnpm run build",
    "validate:all": "pnpm run validate && pnpm run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.5",
    "eslint-plugin-svelte": "^3.20.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  },
  "pnpm": {
    "overrides": {
      "picomatch@^4": "4.0.4",
      "picomatch@^2": "2.3.2"
    }
  }
}
